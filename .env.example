# Copy this file to .env for your local lab, or pass it explicitly with --env-file.
# Do not commit real .env files.

# VMware vmrun.exe path. Keep this only if your VMware install path is non-standard.
VMRUN_PATH="C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe"

# Guest credentials used by VMware guest operations.
VMWARE_GUEST_USER=Administrator
VMWARE_GUEST_PASSWORD=change_me

# Optional vmrest/MCP credentials if you also use the VMware MCP server.
VMWARE_HOST=localhost
VMWARE_PORT=8697
VMWARE_USERNAME=
VMWARE_PASSWORD=
